# This .gitignore file should be placed at the root of your Unity project directory

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Dd]ebug*/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
.idea/

# User-specific files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb
*.sln.docstates

# Unity3D generated meta files
sysinfo.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.apk
*.unitypackage

# Visual Studio
.vscode/
*.code-workspace

# TextMesh Pro
*.tmpro
